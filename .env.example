# Entrypoints load this file via dotenv (`import "dotenv/config"`). Copy to `.env` in the project root.
# --- Local stdio MCP (Cursor envFile) + HTTP default site (`/setup` uses JIRA_BASE_URL or DEFAULT_JIRA_BASE_URL) ---
JIRA_BASE_URL=https://mehulsworkspace-39984003.atlassian.net

# --- Hosted HTTP server: required for /setup + device tokens (same value as JIRA_BASE_URL is fine) ---
# When set, clients can omit X-Jira-Base-Url if everyone uses the same Jira Cloud site.
# DEFAULT_JIRA_BASE_URL=https://your-site.atlassian.net

# --- HTTP server bind ---
# MCP_HTTP_PORT=3333
# MCP_HTTP_HOST=0.0.0.0
# MCP_ALLOWED_HOSTS=mcp.yourcompany.com,localhost

# --- Hosted: device linking UI + token storage ---
# MCP_PUBLIC_ORIGIN=https://jira-mcp.yourcompany.com
# MCP_SETUP_SECRET=long-random-secret
# MCP_DATA_DIR=./data
# SKIP_PRODUCTION_CONFIG_VALIDATION=true

# --- JiraFlow (git / MR on hosted + local) ---
# JIRAFLOW_WORKSPACE_ROOT=/var/jiraflow/workspaces
# GITHUB_TOKEN=
# GITLAB_TOKEN=
